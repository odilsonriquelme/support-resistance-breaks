//@version=6
indicator(
     title              = "Suporte e Resistência @ape_bitcoiner V1.0",
     overlay            = true,
     max_bars_back      = 1000,
     max_lines_count    = 100,
     max_labels_count   = 250
 )

// ═══════════════════════════ ENTRADAS ══════════════════════════════════════
grpPiv = "Pivôs"
leftBars     = input.int(15, "Barras à Esquerda", minval = 1, group = grpPiv)
rightBars    = input.int(15, "Barras à Direita",  minval = 1, group = grpPiv)

grpBrk = "Rompimentos"
showBreaks   = input.bool(true,  "Mostrar Rótulos de Rompimento",          group = grpBrk)
showWicks    = input.bool(true,  "Mostrar Rótulos de Pavio Alta/Baixa",    group = grpBrk)
useVolFilter = input.bool(true,  "Exigir Confirmação por Volume",          group = grpBrk)
volumeThresh = input.float(20,   "Limite do Oscilador de Volume (%)",      group = grpBrk)
confirmClose = input.bool(true,  "Confirmar Apenas no Fechamento (sem repaint)", group = grpBrk)

grpAtr = "Filtro ATR"
useAtrFilter = input.bool(true,  "Filtrar Rompimentos Fracos por ATR", group = grpAtr)
atrLen       = input.int(14,     "Período do ATR", minval = 1,         group = grpAtr)
atrMult      = input.float(0.25, "Tamanho Mínimo do Rompimento (× ATR)", step = 0.05, group = grpAtr,
                            tooltip = "O fechamento precisa ultrapassar o nível em pelo menos esse múltiplo de ATR para ser considerado rompimento real.")

grpMtf = "S/R do Tempo Gráfico Superior"
useHtf       = input.bool(false, "Exibir Níveis do TF Superior",        group = grpMtf)
htfTf        = input.timeframe("D", "Tempo Gráfico Superior",           group = grpMtf)
htfLeft      = input.int(5,  "Barras à Esquerda (TF Superior)",  minval = 1, group = grpMtf)
htfRight     = input.int(5,  "Barras à Direita (TF Superior)",  minval = 1, group = grpMtf)
htfResColor  = input.color(color.new(color.red, 50), "Resistência (TF Superior)", group = grpMtf)
htfSupColor  = input.color(color.new(color.green, 50), "Suporte (TF Superior)",     group = grpMtf)

grpRetest = "Reteste"
useRetest    = input.bool(true,  "Detectar Retestes",                 group = grpRetest)
retestBars   = input.int(20,     "Máx. Barras p/ Esperar Reteste", minval = 1, group = grpRetest)
retestProx   = input.float(0.5,  "Proximidade do Toque (× ATR)", step = 0.05, group = grpRetest,
                            tooltip = "Distância máxima entre o preço e o nível rompido para contar como toque.")

grpTable = "Tabela de Níveis"
showTable    = input.bool(true, "Mostrar Tabela de Níveis Ativos", group = grpTable)

grpStyle = "Estilo"
resColor     = input.color(color.new(color.red, 0), "Resistência", group = grpStyle)
supColor     = input.color(color.new(color.green, 0), "Suporte",     group = grpStyle)
lineWidth    = input.int(2, "Espessura da Linha", minval = 1, maxval = 5, group = grpStyle)
extendRight  = input.bool(true, "Estender Linhas para a Direita",  group = grpStyle)
showPriceTag = input.bool(true, "Mostrar Etiqueta de Preço na Linha", group = grpStyle,
                          tooltip = "Rótulo flutuante na ponta direita de cada linha S/R mostrando o preço.")

grpAlert = "Alertas"
alertOnce    = input.bool(true, "Alertar Apenas Uma Vez por Nível", group = grpAlert)

// ═══════════════════════════ SÉRIES PRINCIPAIS ═════════════════════════════
atr   = ta.atr(atrLen)
ph    = ta.pivothigh(leftBars, rightBars)
pl    = ta.pivotlow(leftBars, rightBars)

short = ta.ema(volume, 5)
long_ = ta.ema(volume, 10)
osc   = 100.0 * (short - long_) / long_
volOK = not useVolFilter or osc > volumeThresh

barOK = not confirmClose or barstate.isconfirmed

// ═══════════════════════════ LINHAS DE S/R PRINCIPAIS ══════════════════════
var line  resLine    = na
var line  supLine    = na
var float resLevel   = na
var float supLevel   = na
var int   resBarIdx  = na
var int   supBarIdx  = na
var bool  resBroken  = false
var bool  supBroken  = false
var int   resBrkBar  = na
var int   supBrkBar  = na

if not na(ph)
    if not na(resLine)
        line.delete(resLine)
    resLevel  := ph
    resBarIdx := bar_index - rightBars
    resBroken := false
    resBrkBar := na
    resLine   := line.new(resBarIdx, ph, bar_index, ph,
                          color = resColor, width = lineWidth,
                          extend = extendRight ? extend.right : extend.none)

if not na(pl)
    if not na(supLine)
        line.delete(supLine)
    supLevel  := pl
    supBarIdx := bar_index - rightBars
    supBroken := false
    supBrkBar := na
    supLine   := line.new(supBarIdx, pl, bar_index, pl,
                          color = supColor, width = lineWidth,
                          extend = extendRight ? extend.right : extend.none)

// ═══════════════════════════ NÍVEIS DO TF SUPERIOR ═════════════════════════
[htfPh, htfPl] = request.security(syminfo.tickerid, htfTf,
     [ta.pivothigh(htfLeft, htfRight), ta.pivotlow(htfLeft, htfRight)],
     lookahead = barmerge.lookahead_off)

var line htfResLine = na
var line htfSupLine = na

htfPhChanged = not na(htfPh) and (na(htfPh[1]) or htfPh != htfPh[1])
htfPlChanged = not na(htfPl) and (na(htfPl[1]) or htfPl != htfPl[1])

if useHtf and htfPhChanged
    if not na(htfResLine)
        line.delete(htfResLine)
    htfResLine := line.new(bar_index - 1, htfPh, bar_index, htfPh,
                           color = htfResColor, width = lineWidth,
                           style = line.style_dashed,
                           extend = extendRight ? extend.right : extend.none)

if useHtf and htfPlChanged
    if not na(htfSupLine)
        line.delete(htfSupLine)
    htfSupLine := line.new(bar_index - 1, htfPl, bar_index, htfPl,
                           color = htfSupColor, width = lineWidth,
                           style = line.style_dashed,
                           extend = extendRight ? extend.right : extend.none)

// ═══════════════════════════ DETECÇÃO DE ROMPIMENTO ════════════════════════
bullWick = (open - low) > (close - open)
bearWick = (open - close) < (high - open)

atrOKres = not useAtrFilter or (close - resLevel) >= atrMult * atr
atrOKsup = not useAtrFilter or (supLevel - close) >= atrMult * atr

resCross = ta.crossover(close,  resLevel)
supCross = ta.crossunder(close, supLevel)

resBreakRaw = not na(resLevel) and resCross and barOK and atrOKres
supBreakRaw = not na(supLevel) and supCross and barOK and atrOKsup

resBreak = resBreakRaw and volOK and (not alertOnce or not resBroken)
supBreak = supBreakRaw and volOK and (not alertOnce or not supBroken)

if resBreak
    resBroken := true
    resBrkBar := bar_index
if supBreak
    supBroken := true
    supBrkBar := bar_index

// Rótulos de rompimento
if showBreaks and resBreak and not bullWick
    label.new(bar_index, low, "R",
              style = label.style_label_up, color = color.new(color.green, 0),
              textcolor = color.white, size = size.tiny,
              tooltip = "Rompimento de Resistência")
if showBreaks and supBreak and not bearWick
    label.new(bar_index, high, "R",
              style = label.style_label_down, color = color.new(color.red, 0),
              textcolor = color.white, size = size.tiny,
              tooltip = "Rompimento de Suporte")
if showWicks and resBreakRaw and bullWick
    label.new(bar_index, low, "Pavio Alta",
              style = label.style_label_up, color = color.new(color.green, 0),
              textcolor = color.white, size = size.tiny)
if showWicks and supBreakRaw and bearWick
    label.new(bar_index, high, "Pavio Baixa",
              style = label.style_label_down, color = color.new(color.red, 0),
              textcolor = color.white, size = size.tiny)

// ═══════════════════════════ DETECÇÃO DE RETESTE ═══════════════════════════
body      = math.abs(close - open)
upperWick = high - math.max(close, open)
lowerWick = math.min(close, open) - low

bullReversal = (lowerWick >= 2 * body and close > open) or
               (close > open and close[1] < open[1] and close > open[1] and open < close[1])
bearReversal = (upperWick >= 2 * body and close < open) or
               (close < open and close[1] > open[1] and close < open[1] and open > close[1])

var bool resRetested = false
var bool supRetested = false

if not na(ph)
    resRetested := false
if not na(pl)
    supRetested := false

withinResWindow = useRetest and resBroken and not resRetested and
                  not na(resBrkBar) and (bar_index - resBrkBar) <= retestBars
withinSupWindow = useRetest and supBroken and not supRetested and
                  not na(supBrkBar) and (bar_index - supBrkBar) <= retestBars

resRetest = withinResWindow and
             low <= resLevel + retestProx * atr and
             close > resLevel and
             bullReversal

supRetest = withinSupWindow and
             high >= supLevel - retestProx * atr and
             close < supLevel and
             bearReversal

if resRetest
    resRetested := true
    label.new(bar_index, low, "RT",
              style = label.style_label_up, color = color.new(color.teal, 0),
              textcolor = color.white, size = size.small,
              tooltip = "Reteste da resistência rompida + barra de reversão de alta")

if supRetest
    supRetested := true
    label.new(bar_index, high, "RT",
              style = label.style_label_down, color = color.new(color.orange, 0),
              textcolor = color.white, size = size.small,
              tooltip = "Reteste do suporte rompido + barra de reversão de baixa")

// ═══════════════════════════ ETIQUETAS DE PREÇO NAS LINHAS ═════════════════
var label resTag    = na
var label supTag    = na
var label htfResTag = na
var label htfSupTag = na

if barstate.islast
    if not na(resTag)
        label.delete(resTag)
    if not na(supTag)
        label.delete(supTag)
    if not na(htfResTag)
        label.delete(htfResTag)
    if not na(htfSupTag)
        label.delete(htfSupTag)

    if showPriceTag and not na(resLevel)
        resTag := label.new(bar_index + 5, resLevel,
                            text  = "R  " + str.tostring(resLevel, format.mintick),
                            xloc  = xloc.bar_index,
                            yloc  = yloc.price,
                            style = label.style_label_left,
                            color = resColor,
                            textcolor = color.white,
                            size  = size.small)

    if showPriceTag and not na(supLevel)
        supTag := label.new(bar_index + 5, supLevel,
                            text  = "S  " + str.tostring(supLevel, format.mintick),
                            xloc  = xloc.bar_index,
                            yloc  = yloc.price,
                            style = label.style_label_left,
                            color = supColor,
                            textcolor = color.white,
                            size  = size.small)

    if showPriceTag and useHtf and not na(htfPh)
        htfResTag := label.new(bar_index + 5, htfPh,
                               text  = "TF↑ R  " + str.tostring(htfPh, format.mintick),
                               xloc  = xloc.bar_index,
                               yloc  = yloc.price,
                               style = label.style_label_left,
                               color = htfResColor,
                               textcolor = color.white,
                               size  = size.small)

    if showPriceTag and useHtf and not na(htfPl)
        htfSupTag := label.new(bar_index + 5, htfPl,
                               text  = "TF↑ S  " + str.tostring(htfPl, format.mintick),
                               xloc  = xloc.bar_index,
                               yloc  = yloc.price,
                               style = label.style_label_left,
                               color = htfSupColor,
                               textcolor = color.white,
                               size  = size.small)

// ═══════════════════════════ TABELA DE NÍVEIS ══════════════════════════════
var table tbl = table.new(position.top_left, 2, 6,
                          border_width = 1, frame_width = 1,
                          frame_color = color.new(color.gray, 70))

f_pct(level) =>
    na(level) ? na : (close - level) / level * 100.0

if showTable and barstate.islast
    table.clear(tbl, 0, 0, 1, 5)
    table.cell(tbl, 0, 0, "Nível",        bgcolor = color.new(color.gray, 70), text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 0, "Preço / Δ%",   bgcolor = color.new(color.gray, 70), text_color = color.white, text_size = size.small)

    resTxt = na(resLevel) ? "—" : str.tostring(resLevel, format.mintick) +
             "  (" + str.tostring(f_pct(resLevel), "0.00") + "%)"
    resStatus = na(resLevel) ? "Resistência" :
                 resBroken ? "R · rompida" : "R · ativa"
    table.cell(tbl, 0, 1, resStatus, text_color = resColor, text_size = size.small)
    table.cell(tbl, 1, 1, resTxt,    text_color = color.white, text_size = size.small)

    supTxt = na(supLevel) ? "—" : str.tostring(supLevel, format.mintick) +
             "  (" + str.tostring(f_pct(supLevel), "0.00") + "%)"
    supStatus = na(supLevel) ? "Suporte" :
                 supBroken ? "S · rompido" : "S · ativo"
    table.cell(tbl, 0, 2, supStatus, text_color = supColor, text_size = size.small)
    table.cell(tbl, 1, 2, supTxt,    text_color = color.white, text_size = size.small)

    if useHtf
        htfResTxt = na(htfPh) ? "—" : str.tostring(htfPh, format.mintick) +
                     "  (" + str.tostring(f_pct(htfPh), "0.00") + "%)"
        table.cell(tbl, 0, 3, "R · TF↑ (" + htfTf + ")", text_color = htfResColor, text_size = size.small)
        table.cell(tbl, 1, 3, htfResTxt, text_color = color.white, text_size = size.small)

        htfSupTxt = na(htfPl) ? "—" : str.tostring(htfPl, format.mintick) +
                     "  (" + str.tostring(f_pct(htfPl), "0.00") + "%)"
        table.cell(tbl, 0, 4, "S · TF↑ (" + htfTf + ")", text_color = htfSupColor, text_size = size.small)
        table.cell(tbl, 1, 4, htfSupTxt, text_color = color.white, text_size = size.small)

    table.cell(tbl, 0, 5, "ATR(" + str.tostring(atrLen) + ")",
               text_color = color.new(color.white, 30), text_size = size.small)
    table.cell(tbl, 1, 5, str.tostring(atr, format.mintick),
               text_color = color.new(color.white, 30), text_size = size.small)

// ═══════════════════════════ ALERTAS ═══════════════════════════════════════
alertcondition(supBreakRaw and volOK, title = "Suporte Rompido",
               message = "Suporte rompido em {{close}} no {{ticker}} ({{interval}})")
alertcondition(resBreakRaw and volOK, title = "Resistência Rompida",
               message = "Resistência rompida em {{close}} no {{ticker}} ({{interval}})")
alertcondition(resRetest, title = "Reteste de Resistência",
               message = "Reteste de resistência em {{close}} no {{ticker}} ({{interval}})")
alertcondition(supRetest, title = "Reteste de Suporte",
               message = "Reteste de suporte em {{close}} no {{ticker}} ({{interval}})")
